# Use the Supabase URI you prefer. If `migrate deploy` fails through the pooler, switch this to
# the "Direct connection" string from Project Settings → Database (host db.*.supabase.co:5432).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# Optional — Prisma 7 + pg adapter: set to false if you hit TLS / certificate errors (e.g. P1010).
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

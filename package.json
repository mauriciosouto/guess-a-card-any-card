{
  "name": "guess-a-card-any-card",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@gac/web",
    "dev:web": "npm run dev --workspace=@gac/web",
    "dev:api": "npm run dev --workspace=@gac/api",
    "build": "npm run build --workspace=@gac/web",
    "build:api": "npm run build --workspace=@gac/api",
    "start": "npm run start --workspace=@gac/web",
    "start:api": "npm run start --workspace=@gac/api",
    "lint": "npm run lint --workspace=@gac/web",
    "test": "vitest run",
    "db:generate": "npm run db:generate --workspace=@gac/api",
    "db:migrate:dev": "npm run db:migrate:dev --workspace=@gac/api",
    "db:deploy": "npm run db:deploy --workspace=@gac/api",
    "db:push": "npm run db:push --workspace=@gac/api",
    "db:seed": "npm run db:seed --workspace=@gac/api",
    "db:studio": "npm run db:studio --workspace=@gac/api",
    "realtime:dev": "npm run realtime:dev --workspace=@gac/api"
  },
  "devDependencies": {
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}

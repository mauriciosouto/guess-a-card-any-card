{
  "name": "@gac/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "realtime:dev": "tsx scripts/coop-realtime-server.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@flesh-and-blood/cards": "^3.6.239",
    "@gac/shared": "*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@hono/node-server": "^1.19.9",
    "dotenv": "^16.4.7",
    "hono": "^4.12.9",
    "pg": "^8.14.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/ws": "^8.18.1",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js (all workspaces) ---
**/.next/
**/out/

# --- Bundlers / caches ---
.turbo/
**/.turbo/
*.tsbuildinfo
.eslintcache

# --- Test & coverage ---
coverage/
.nyc_output/

# --- Production / pack outputs ---
build/
**/dist/
*.tgz

# --- Prisma (API): client is generated; never commit ---
apps/api/src/generated/prisma/

# --- Env (keep example only) ---
.env
.env.*
!.env.example

# --- Vercel / deploy tooling ---
.vercel

# --- OS & editors ---
.DS_Store
*.pem
Thumbs.db
.idea/
*.swp
*.swo

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# --- Next.js TypeScript bootstrap (regenerated by `next dev` / `next build`) ---
apps/web/next-env.d.ts
